# ==================== Environment Configuration ====================

# Python Environment
PYTHON_ENV=development  # development, staging, production

# ==================== GPU Configuration ====================
CUDA_VISIBLE_DEVICES=0  # GPU device IDs
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
TORCH_HOME=/path/to/torch/models

# ==================== Model Configuration ====================
# ColPali Model
COLPALI_MODEL_NAME=colpali-base  # Base model or custom variant
COLPALI_DEVICE=cuda:0

# ImageBind Model
IMAGEBIND_MODEL=imagebind_large

# MM-R5 Model
MM_R5_MODEL_PATH=./models/mm-r5-7b  # Path to MM-R5 model weights
MM_R5_DEVICE=cuda:1
MM_R5_BATCH_SIZE=4

# ==================== Database Configuration ====================
# LanceDB
LANCEDB_PATH=./data/vector_store/lancedb
LANCEDB_MODE=local  # local or remote

# PostgreSQL (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/drl_ppt_db

# Redis
REDIS_URL=redis://localhost:6379

# ==================== Message Queue Configuration ====================
# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Kafka (alternative)
KAFKA_BROKERS=localhost:9092

# ==================== API Configuration ====================
# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ==================== Streamlit UI ====================
STREAMLIT_SERVER_RUNON_SAVE=true
STREAMLIT_CLIENT_THEME=light  # light or dark

# ==================== Logging ====================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
LOG_OUTPUT_DIR=./logs

# ==================== Monitoring ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ==================== System Configuration ====================
# Batch Processing
BATCH_SIZE_RETRIEVAL=500
BATCH_SIZE_REASONING=4
BATCH_SIZE_VERIFICATION=10

# Timeouts (ms)
TIMEOUT_RETRIEVAL=200
TIMEOUT_REASONING=30000
TIMEOUT_VERIFICATION=2000

# ==================== Feature Flags ====================
ENABLE_REASONING=true
ENABLE_VERIFICATION=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_DIVERSITY_RANKING=false

# ==================== Data Paths ====================
PPT_DATA_PATH=./data/ppt_samples
VECTOR_STORE_PATH=./data/vector_store
MODEL_CACHE_PATH=./models
